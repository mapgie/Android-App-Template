<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Add permissions here as your app requires them.
        Only declare permissions your app actually uses — each one is a user-visible
        consent prompt and a Play Store declaration.

        Common examples:
          <uses-permission android:name="android.permission.USE_BIOMETRIC" />
          <uses-permission android:name="android.permission.INTERNET" />

        If you declare SCHEDULE_EXACT_ALARM/USE_EXACT_ALARM or POST_NOTIFICATIONS for
        reminders/alarms, also wire up `permission/PermissionHelper.kt` in your settings
        screen — these can't be re-requested with a runtime dialog once denied, so users
        need a deep link to the right Settings page (see LESSONS.md).
    -->

    <!-- Uncomment if your app shows notifications (required Android 13+) -->
    <!-- <uses-permission android:name="android.permission.POST_NOTIFICATIONS" /> -->

    <!-- Uncomment if your app uses exact alarms (required Android 12+).
         SCHEDULE_EXACT_ALARM requires user approval via the system Settings dialog;
         USE_EXACT_ALARM is granted automatically but is restricted to specific app
         categories on Google Play. Use SCHEDULE_EXACT_ALARM unless you qualify. -->
    <!-- <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" /> -->
    <!-- <uses-permission android:name="android.permission.USE_EXACT_ALARM" /> -->

    <!-- Uncomment if your app reschedules alarms after device reboot -->
    <!-- <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" /> -->

    <!-- Uncomment if your app needs alarm-channel notifications to bypass Do Not Disturb.
         Requires the user to grant access via Settings > Apps > Special app access. -->
    <!-- <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" /> -->

    <application
        android:name=".MyApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Uncomment when using alarm/reminder functionality (AlarmReceiver, AlarmActionReceiver,
            BootReceiver). Also uncomment the matching permission declarations above, and ensure
            the Hilt WorkManager initializer is set up if you use BootWorker.
        -->
        <!--
        <receiver android:name=".alarm.AlarmReceiver"       android:exported="false" />
        <receiver android:name=".alarm.AlarmActionReceiver" android:exported="false" />
        <receiver android:name=".alarm.BootReceiver"        android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
        -->

        <!-- Disable WorkManager's automatic startup-library initialization.
             Required because MyApplication implements Configuration.Provider —
             WorkManager must be initialized on demand via HiltWorkerFactory instead. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
            FileProvider for data export / sharing.
            Exposes files from cacheDir/exports/ via a content:// URI so the share
            sheet can deliver files to any target app without broad storage permissions.
            android:exported="false" is required — grantUriPermissions handles access.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
